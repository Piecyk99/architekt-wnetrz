# Wklej URL swojego workera po deployu (np. https://architekt-wnetrz.<subdomena>.workers.dev)
NEXT_PUBLIC_API_URL=http://localhost:8787

# SHARED_SECRET — ten sam co ustawiłeś przez `wrangler secret put SHARED_SECRET` w workerze.
# Aplikacja jest tylko dla Ciebie, więc trzymanie sekretu w client-side jest OK
# (pełni rolę hasła do API). Nie udostępniaj URL aplikacji innym.
NEXT_PUBLIC_SHARED_SECRET=zmien-mnie-na-cos-losowego
